@article{Smith2015,
  author = {Smith, John A. and Johnson, Mary B.},
  title = {Efficacy of cognitive behavioral therapy for major depression: A randomized controlled trial},
  journal = {Journal of Clinical Psychology},
  year = {2015},
  volume = {71},
  number = {3},
  pages = {245-258},
  doi = {10.1002/jclp.22145},
  pmid = {25601234},
  abstract = {Background: Cognitive behavioral therapy (CBT) is widely used for depression. Methods: We randomized 120 adults with MDD to CBT (n=60) or waitlist control (n=60). Results: CBT significantly reduced HDRS scores (d=0.85). Conclusions: CBT is effective for MDD.},
  keywords = {depression, CBT, randomized controlled trial},
  note = {round-01}
}

@article{Chen2018,
  author = {Chen, Wei and Liu, Xiaoming and Zhang, Hui},
  title = {Group cognitive behavioral therapy versus treatment as usual for depression: Results from a multicenter trial},
  journal = {Psychological Medicine},
  year = {2018},
  volume = {48},
  number = {12},
  pages = {2012-2023},
  doi = {10.1017/S0033291718000284},
  pmid = {29456789},
  abstract = {Objective: To compare group CBT with TAU in depressed patients. Method: 200 participants were randomized. Results: Group CBT showed superior outcomes (SMD=-0.72). Conclusion: Group CBT is effective.},
  keywords = {group therapy, depression, CBT},
  note = {round-01}
}

@article{Williams2020,
  author = {Williams, Sarah and Brown, David and Taylor, Emma},
  title = {Internet-delivered CBT for major depressive disorder: A pilot randomized trial},
  journal = {Internet Interventions},
  year = {2020},
  volume = {22},
  pages = {100345},
  doi = {10.1016/j.invent.2020.100345},
  pmid = {32789012},
  abstract = {Introduction: Internet-delivered CBT (iCBT) may increase access to treatment. Methods: 80 adults with MDD randomized to iCBT or waitlist. Results: iCBT reduced depression (d=0.65). Discussion: iCBT is a promising delivery method.},
  keywords = {internet intervention, depression, digital health},
  note = {round-01}
}

@article{Garcia2019,
  author = {Garcia, Maria and Rodriguez, Carlos},
  title = {Cognitive therapy for treatment-resistant depression: A randomized trial},
  journal = {British Journal of Psychiatry},
  year = {2019},
  volume = {215},
  number = {4},
  pages = {578-586},
  doi = {10.1192/bjp.2019.156},
  pmid = {31234567},
  abstract = {Aims: To test CBT in treatment-resistant depression. Method: 150 patients randomized to CBT+TAU vs TAU alone. Results: CBT augmentation improved outcomes (OR=2.3). Conclusions: CBT benefits treatment-resistant cases.},
  keywords = {treatment-resistant depression, CBT, augmentation},
  note = {round-01}
}

@article{Tanaka2021,
  author = {Tanaka, Yuki and Yamamoto, Kenji and Suzuki, Akiko},
  title = {Brief cognitive behavioral therapy for depression in primary care: A cluster randomized trial},
  journal = {Family Practice},
  year = {2021},
  volume = {38},
  number = {5},
  pages = {601-610},
  doi = {10.1093/fampra/cmab045},
  pmid = {34567890},
  abstract = {Background: Brief CBT may be feasible in primary care. Methods: 24 practices randomized, 480 patients enrolled. Results: Brief CBT improved depression scores vs usual care (d=0.52). Conclusion: Brief CBT is effective in primary care settings.},
  keywords = {primary care, brief intervention, depression},
  note = {round-01}
}

@article{Anderson2017,
